{
  "projectName": "WorkLogger",
  "description": "Time tracking and project management application built with Next.js 16, Prisma 7, and MySQL. Includes client portal for sharing project data with clients.",
  "version": "0.2.0",
  "lastUpdated": "2026-01-15",

  "techStack": {
    "framework": "Next.js 16.0.10 (App Router)",
    "language": "TypeScript 5",
    "runtime": "React 19.2.1",
    "database": "MySQL 8.0 (via Prisma 7 + MariaDB adapter)",
    "authentication": "NextAuth.js 4.24.13 (JWT strategy)",
    "payment": "Stripe",
    "email": "Resend",
    "styling": "Tailwind CSS 4.1.18",
    "testing": "Jest 30.2.0",
    "i18n": "next-intl 4.6.1"
  },

  "projectStructure": {
    "rootDirectory": "/home/jarek/projects/work_logger",
    "webDirectory": "/home/jarek/projects/work_logger/web",
    "mainDirectories": {
      "src/app": "Next.js App Router pages and API routes",
      "src/app/(auth)": "Authentication pages (login, register, verify-email, password reset)",
      "src/app/api": "API endpoints",
      "src/app/dashboard": "Protected dashboard pages",
      "src/app/portal/[hash]": "Client portal with hash-based access",
      "src/app/portal/[hash]/(auth)": "Portal authentication pages (email entry, code verification)",
      "src/app/portal/[hash]/(authenticated)": "Portal protected pages (dashboard, projects, etc.)",
      "src/app/pricing": "Subscription pricing page",
      "src/app/components": "React components organized by feature",
      "src/app/components/portal": "Portal-specific components",
      "src/lib": "Utility functions, configurations, database queries",
      "src/lib/queries": "Prisma database query functions",
      "src/lib/queries/portal": "Portal-specific query functions filtered by clientId",
      "src/__tests__": "Jest test suites",
      "src/i18n": "Internationalization configuration",
      "prisma": "Database schema and migrations",
      "messages": "Translation files (pl.json, en.json)",
      "public": "Static assets"
    }
  },

  "databaseSchema": {
    "provider": "MySQL 8.0",
    "orm": "Prisma 7.2.0 with MariaDB adapter",
    "models": {
      "User": {
        "purpose": "User accounts with auth and subscription data. Also used for portal users.",
        "fields": {
          "id": "Int @id @default(autoincrement())",
          "name": "String",
          "email": "String @unique",
          "password": "String (bcrypt hashed)",
          "emailVerified": "DateTime?",
          "createdAt": "DateTime @default(now())",
          "resetPasswordToken": "String?",
          "resetPasswordExpires": "DateTime?",
          "verificationCode": "String? (6-digit)",
          "verificationCodeExpires": "DateTime?",
          "stripeCustomerId": "String? @unique",
          "stripeSubscriptionId": "String? @unique",
          "stripePriceId": "String?",
          "stripeCurrentPeriodEnd": "DateTime?",
          "subscriptionStatus": "String? (active/canceled/past_due)",
          "bypassSubscription": "Boolean @default(false)",
          "isPortalUser": "Boolean @default(false) - Indicates portal user",
          "portalClientId": "Int? - Links portal user to specific client"
        },
        "relations": ["clients", "projects", "calendarevents", "incomes", "portalClient"]
      },
      "Client": {
        "purpose": "Client entities for billing. Hash is used for portal access URL.",
        "fields": {
          "id": "Int @id",
          "name": "String",
          "hourlyRate": "Decimal(10,2)",
          "hash": "String @unique - Used in portal URL /portal/[hash]",
          "status": "Int @db.TinyInt @default(1)",
          "userId": "Int",
          "createdAt": "DateTime"
        },
        "relations": ["user", "projects", "portalUsers"]
      },
      "Project": {
        "purpose": "Projects linked to clients",
        "fields": {
          "id": "Int @id",
          "name": "String",
          "color": "String?",
          "hourlyRate": "Decimal(10,2)",
          "userId": "Int",
          "status": "Int @db.TinyInt @default(0) (0=active, 1=finished, 2=archived)",
          "clientId": "Int",
          "createdAt": "DateTime"
        },
        "relations": ["user", "client", "calendarevents", "incomes"]
      },
      "CalendarEvent": {
        "purpose": "Time tracking entries",
        "fields": {
          "id": "Int @id",
          "description": "String",
          "projectId": "Int",
          "userId": "Int",
          "hours": "Decimal(10,2)",
          "hourlyRate": "Decimal(10,2)",
          "start": "DateTime",
          "end": "DateTime",
          "createdAt": "DateTime"
        },
        "relations": ["user", "project"]
      },
      "Income": {
        "purpose": "Payment records for projects",
        "fields": {
          "id": "Int @id",
          "projectId": "Int",
          "userId": "Int",
          "value": "Decimal(10,2)",
          "createdAt": "DateTime"
        },
        "relations": ["user", "project"]
      }
    }
  },

  "authentication": {
    "provider": "NextAuth.js 4.24.13",
    "strategy": "JWT",
    "credentialsProviders": {
      "credentials": "Email + Password for regular users",
      "portal-credentials": "Email + Client Hash for portal users (passwordless)"
    },
    "passwordHashing": "bcryptjs (12 rounds)",
    "flow": {
      "registration": [
        "1. User submits registration form",
        "2. Password hashed with bcrypt",
        "3. 6-digit verification code generated",
        "4. User saved to DB with code",
        "5. Verification email sent via Resend",
        "6. Redirect to /verify-email"
      ],
      "emailVerification": [
        "1. User enters 6-digit code",
        "2. Code validated (10 min expiry)",
        "3. emailVerified set to current timestamp",
        "4. Redirect to /login"
      ],
      "login": [
        "1. User submits email + password",
        "2. Check if emailVerified is set",
        "3. Compare password with bcrypt",
        "4. Create JWT session",
        "5. Redirect to /dashboard"
      ],
      "passwordReset": [
        "1. User requests reset via email",
        "2. SHA-256 hashed token generated (30 min expiry)",
        "3. Email with reset link sent",
        "4. User sets new password",
        "5. Token cleared from DB"
      ],
      "portalLogin": [
        "1. Client opens /portal/[hash] link",
        "2. Client enters email address",
        "3. Portal user created or found (isPortalUser=true)",
        "4. 6-digit verification code sent via email",
        "5. Client enters code on /portal/[hash]/verify",
        "6. emailVerified set, JWT session created",
        "7. Redirect to /portal/[hash]/dashboard"
      ]
    },
    "jwtTokenFields": {
      "id": "User ID",
      "isPortalUser": "Boolean - true for portal users",
      "portalClientId": "Int - Client ID for portal users",
      "portalClientHash": "String - Client hash for redirects"
    },
    "files": {
      "config": "src/lib/auth.ts",
      "wrapper": "src/auth.ts",
      "routes": "src/app/api/auth/[...nextauth]/route.ts",
      "types": "src/types/next-auth.d.ts"
    }
  },

  "subscriptionSystem": {
    "provider": "Stripe",
    "plans": {
      "monthly": {
        "name": "Monthly Plan",
        "price": 29,
        "currency": "USD",
        "interval": "month"
      },
      "yearly": {
        "name": "Yearly Plan",
        "price": 290,
        "currency": "USD",
        "interval": "year",
        "savings": "$58 per year"
      }
    },
    "statuses": ["active", "canceled", "past_due", "trialing"],
    "bypassSubscription": "Boolean field for admin/demo users to skip payment",
    "webhookEvents": [
      "checkout.session.completed",
      "customer.subscription.created",
      "customer.subscription.updated",
      "customer.subscription.deleted",
      "invoice.payment_succeeded",
      "invoice.payment_failed"
    ],
    "files": {
      "config": "src/lib/stripe.ts",
      "subscriptionLogic": "src/lib/subscription.ts",
      "guard": "src/components/SubscriptionGuard.tsx",
      "checkAPI": "src/app/api/subscription/check/route.ts",
      "checkoutAPI": "src/app/api/subscription/create-checkout/route.ts",
      "webhookAPI": "src/app/api/webhooks/stripe/route.ts",
      "pricingPage": "src/app/pricing/page.tsx"
    }
  },

  "internationalization": {
    "framework": "next-intl 4.6.1",
    "locales": ["pl", "en"],
    "defaultLocale": "pl",
    "localeStorage": "Cookie (NEXT_LOCALE)",
    "translationDomains": [
      "common",
      "auth",
      "dashboard",
      "clients",
      "projects",
      "calendar",
      "incomes",
      "reports",
      "subscription",
      "portal"
    ],
    "files": {
      "config": "src/i18n/request.ts",
      "polish": "messages/pl.json",
      "english": "messages/en.json"
    }
  },

  "emailService": {
    "provider": "Resend",
    "fromAddress": "WorkLogger <no-reply@worklogger.augustyniak.xyz>",
    "templates": {
      "verification": "6-digit code, 10 min expiry",
      "passwordReset": "Reset link, 30 min expiry",
      "portalVerification": "6-digit code for portal login, 10 min expiry"
    },
    "file": "src/lib/mail.ts"
  },

